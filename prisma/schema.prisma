// =====================================================================
// RedSalud Te Forma — Campus Virtual · Esquema de base de datos (Prisma)
// Stack: Next.js 16 + Prisma + PostgreSQL
// MVP: roles como enum · 3 tipos de pregunta · plantilla de certificado
// simple (builder visual post-MVP)
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------------------
// Usuarios y roles
// ------------------------------------------------------------------

enum Role {
  ADMIN
  TUTOR
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum DocumentType {
  CC // Cédula de ciudadanía
  CE // Cédula de extranjería
  TI // Tarjeta de identidad
  PA // Pasaporte
}

// Clasificación laboral (distinta del Role de permisos): qué personal de la
// EPS/E.S.E. es cada usuario, para filtrar qué cursos le corresponden.
enum PersonnelType {
  ADMINISTRATIVO
  ASISTENCIAL
}

// Secciones del panel admin que se pueden restringir a un ADMIN puntual (para
// tener "niveles" de administrador: el admin principal no restringe ninguna,
// un admin junior puede tener varias en su lista de restringidas). Dashboard
// no aplica: siempre es accesible para cualquier ADMIN.
enum AdminSection {
  USUARIOS
  CURSOS
  PLANES_CAPACITACION
  INSCRIPCIONES
  CERTIFICADOS
  NOTIFICACIONES
  REPORTES
  CONFIGURACION
}

// Modalidad de nombramiento, tomada de la columna TIPO NOM del plan de cargos
// (la leyenda del propio archivo define los códigos). Todo el que está en el
// plan de cargos ES personal de planta: la estrella de la Fase 7.5 se muestra
// a cualquiera cuyo tipo NO sea CONTRATO_PRESTACION (los contratistas).
enum TipoVinculacion {
  CARRERA_ADMINISTRATIVA // KA
  PROVISIONALIDAD // PRO
  TEMPORAL // TEM
  TRABAJADOR_OFICIAL // T.O
  LIBRE_NOMBRAMIENTO // LNR
  PERIODO_FIJO // P.F
  CONTRATO_PRESTACION // contratistas: no son de planta, no llevan estrella
  OTRO
}

// Cómo entró la persona a la plataforma: el personal de planta lo provisiona
// Talento Humano por importación, no se auto-registra.
enum OrigenRegistro {
  IMPORTACION
  AUTO
}

// Municipio de procedencia. Tabla y no enum: Talento Humano necesita listar,
// filtrar y medir por municipio, y poder agregar municipios sin migración.
model Municipio {
  id           String  @id @default(cuid())
  nombre       String  @unique
  departamento String  @default("Casanare")
  isActive     Boolean @default(true)

  usuarios User[]
}

// Cargo / tipo de profesional. Tabla y no enum: serán muchísimos y de esto
// dependen el filtro del catálogo y las métricas cruzadas del centro de datos.
model Cargo {
  id       String        @id @default(cuid())
  nombre   String        @unique
  // Grupo poblacional al que pertenece el cargo: permite derivar el grupo de
  // una persona cuando la fila importada no lo traiga explícito.
  personnelType PersonnelType
  isActive Boolean       @default(true)

  usuarios User[]

  @@index([personnelType])
}

model User {
  id             String       @id @default(cuid())
  fullName       String
  documentType   DocumentType
  documentNumber String       @unique
  email          String       @unique
  // Identificador de acceso alterno (p. ej. "nombre.apellido"). Se usa cuando
  // la persona no tiene un correo válido propio: puede entrar con esto en vez
  // del correo. Nullable porque la mayoría entra con su correo institucional.
  username       String?      @unique
  phone          String?
  profession     String?
  position       String? // cargo como texto libre (heredado; ver cargoId)
  department     String? // dependencia o área
  // personnelType ES el grupo poblacional (ASISTENCIAL | ADMINISTRATIVO). No
  // se duplica en un campo nuevo: ya determina qué cursos ve cada persona a
  // través de Course.targetAudience.
  personnelType  PersonnelType @default(ADMINISTRATIVO)

  municipioId String?
  municipio   Municipio? @relation(fields: [municipioId], references: [id])
  cargoId     String?
  cargo       Cargo?     @relation(fields: [cargoId], references: [id])

  tipoVinculacion TipoVinculacion @default(CONTRATO_PRESTACION)
  origenRegistro  OrigenRegistro  @default(AUTO)
  provisionedAt   DateTime?
  provisionedBy   String?
  passwordHash   String
  role           Role         @default(STUDENT)
  status         UserStatus   @default(ACTIVE)
  mustChangePassword Boolean  @default(true) // admin crea con contraseña temporal
  // Solo aplica si role = ADMIN: secciones del panel a las que este admin NO
  // tiene acceso (vacío = admin principal, con acceso total). Nunca restringe
  // Dashboard.
  restrictedAdminSections AdminSection[] @default([])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  lastLoginAt    DateTime?

  coursesTutored Course[]       @relation("CourseTutor")
  enrollments    Enrollment[]
  lessonProgress LessonProgress[]
  quizAttempts   QuizAttempt[]
  certificates   Certificate[]
  mediaUploads   Media[]
  auditLogs      AuditLog[]
  trainingPlansAsTutor TrainingPlan[] @relation("TrainingPlanTutor")
  trainingAttendances TrainingAttendance[] @relation("TrainingAttendanceUser")
  trainingAttendancesRegistered TrainingAttendance[] @relation("TrainingAttendanceRegisteredBy")
  surveysCreated  Survey[]         @relation("SurveyCreatedBy")
  surveyResponses SurveyResponse[] @relation("SurveyRespondedBy")

  notificationsCreated  Notification[]     @relation("NotificationCreatedBy")
  notificationsTargeted Notification[]     @relation("NotificationTargetUser")
  notificationReads     NotificationRead[] @relation("NotificationReadBy")
  passwordResets        PasswordResetToken[]

  @@index([role, status])
  @@index([department])
  @@index([personnelType])
  // Dimensiones del centro de datos de Talento Humano (Fase 7.7): todas se
  // usan como filtro global y como eje de agregación.
  @@index([municipioId])
  @@index([cargoId])
  @@index([tipoVinculacion])
}

// ------------------------------------------------------------------
// Cursos y estructura
// ------------------------------------------------------------------

enum CourseType {
  INDUCCION
  REINDUCCION
  CAPACITACION
  OBLIGATORIO
  COMPLEMENTARIO
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EnrollmentMode {
  ASSIGNED // solo asignación por admin
  OPEN     // el estudiante puede inscribirse
}

// A qué personal va dirigido el curso; filtra lo que cada estudiante ve en su catálogo.
enum CourseAudience {
  ADMINISTRATIVO
  ASISTENCIAL
  AMBOS
}

model CourseCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  isActive    Boolean @default(true)

  courses Course[]
}

model Course {
  id               String         @id @default(cuid())
  title            String
  slug             String         @unique
  shortDescription String
  fullDescription  String?
  instructions     String? // indicaciones para el estudiante (HTML enriquecido, mismo tratamiento que Lesson.contentBody)
  imageUrl         String?
  categoryId       String?
  category         CourseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  courseType       CourseType
  durationHours    Int // intensidad horaria (aparece en el certificado)
  status           CourseStatus   @default(DRAFT)
  tutorId          String
  tutor            User           @relation("CourseTutor", fields: [tutorId], references: [id])
  passingScore     Int            @default(80) // % mínimo global del curso
  enrollmentMode   EnrollmentMode @default(ASSIGNED)
  targetAudience   CourseAudience @default(AMBOS)
  isSequential     Boolean        @default(true) // módulos se desbloquean en orden
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  publishedAt      DateTime?

  modules      CourseModule[]
  quizzes      Quiz[]
  enrollments  Enrollment[]
  certificates Certificate[]
  trainingActivities TrainingActivity[]

  @@index([status, courseType])
  @@index([status, targetAudience])
  // Todo el panel del tutor filtra sus cursos por tutorId.
  @@index([tutorId])
}

model CourseModule {
  id          String  @id @default(cuid())
  courseId    String
  course      Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String?
  sortOrder   Int
  isRequired  Boolean @default(true)
  isActive    Boolean @default(true)

  lessons Lesson[]
  quizzes Quiz[]

  @@unique([courseId, sortOrder])
}

enum LessonContentType {
  TEXT
  YOUTUBE
  VIDEO // archivo de video subido al storage privado del proyecto (no YouTube)
  PDF
  IMAGE
  LINK
  MIXED
}

model Lesson {
  id               String            @id @default(cuid())
  moduleId         String
  module           CourseModule      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  contentType      LessonContentType
  contentBody      String? // texto enriquecido (HTML sanitizado)
  videoUrl         String? // URL de YouTube
  fileUrl          String? // PDF / imagen / descargable
  externalUrl      String?
  sortOrder        Int
  isRequired       Boolean           @default(true)
  estimatedMinutes Int?
  isActive         Boolean           @default(true)

  progress LessonProgress[]

  @@unique([moduleId, sortOrder])
}

// ------------------------------------------------------------------
// Cuestionarios (MVP: selección única, múltiple, verdadero/falso)
// ------------------------------------------------------------------

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  OPEN_TEXT // respuesta abierta: se guarda para revisión, no suma al puntaje automático
}

model Quiz {
  id                 String        @id @default(cuid())
  courseId           String
  course             Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  moduleId           String? // null = evaluación final del curso
  module             CourseModule? @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title              String
  description        String?
  passingScore       Int           @default(80) // % mínimo de este quiz
  maxAttempts        Int           @default(2)
  timeLimitMinutes   Int?
  randomizeQuestions Boolean       @default(false)
  randomizeAnswers   Boolean       @default(false)
  showResultsNow     Boolean       @default(true)
  isActive           Boolean       @default(true)

  questions Question[]
  attempts  QuizAttempt[]

  @@index([courseId])
}

model Question {
  id          String       @id @default(cuid())
  quizId      String
  quiz        Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  type        QuestionType
  statement   String
  imageUrl    String? // imagen de apoyo del enunciado (p. ej. posturas a evaluar)
  score       Int          @default(1)
  explanation String? // retroalimentación posterior
  sortOrder   Int
  isActive    Boolean      @default(true)

  options QuestionOption[]
  answers QuizAnswer[]

  @@unique([quizId, sortOrder])
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean  @default(false) // NUNCA exponer al cliente antes de calificar
  sortOrder  Int

  @@unique([questionId, sortOrder])
}

// ------------------------------------------------------------------
// Inscripción y progreso
// ------------------------------------------------------------------

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
}

model Enrollment {
  id                 String           @id @default(cuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId           String
  course             Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status             EnrollmentStatus @default(ACTIVE)
  enrolledAt         DateTime         @default(now())
  startedAt          DateTime?
  completedAt        DateTime?
  deadlineAt         DateTime? // fecha límite si aplica
  progressPercentage Int              @default(0)
  finalScore         Int? // promedio de quizzes al completar

  lessonProgress LessonProgress[]
  quizAttempts   QuizAttempt[]
  certificate    Certificate?

  @@unique([userId, courseId])
  @@index([courseId, status])
}

enum ProgressStatus {
  PENDING
  COMPLETED
}

model LessonProgress {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  enrollmentId String
  enrollment   Enrollment     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  status       ProgressStatus @default(PENDING)
  completedAt  DateTime?

  @@unique([userId, lessonId])
  @@index([enrollmentId])
}

model QuizAttempt {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId        String
  quiz          Quiz       @relation(fields: [quizId], references: [id], onDelete: Cascade)
  enrollmentId  String
  enrollment    Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  attemptNumber Int
  score         Int? // % obtenido (null mientras está en curso)
  passed        Boolean?
  startedAt     DateTime   @default(now())
  finishedAt    DateTime?

  answers QuizAnswer[]

  @@unique([userId, quizId, attemptNumber])
}

model QuizAnswer {
  id                String      @id @default(cuid())
  attemptId         String
  attempt           QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId        String
  question          Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOptionIds String[] // ids de QuestionOption elegidos
  textAnswer        String? // respuesta libre (preguntas de tipo OPEN_TEXT)
  isCorrect         Boolean
  scoreObtained     Int

  @@unique([attemptId, questionId])
}

// ------------------------------------------------------------------
// Certificados
// ------------------------------------------------------------------

enum CertificateStatus {
  VALID
  REVOKED
}

model CertificateTemplate {
  id                 String   @id @default(cuid())
  name               String
  backgroundImageUrl String?
  layoutJson         Json? // reservado para el builder visual (post-MVP)
  isDefault          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  certificates Certificate[]
}

model Certificate {
  id              String              @id @default(cuid())
  userId          String
  user            User                @relation(fields: [userId], references: [id])
  courseId        String
  course          Course              @relation(fields: [courseId], references: [id])
  enrollmentId    String              @unique
  enrollment      Enrollment          @relation(fields: [enrollmentId], references: [id])
  templateId      String?
  template        CertificateTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  certificateCode String              @unique // RSC-2026-XXXXXX
  validationHash  String              @unique // hash firmado para el QR
  pdfUrl          String?
  issuedAt        DateTime            @default(now())
  status          CertificateStatus   @default(VALID)
  revokedAt       DateTime?
  revokedReason   String?

  @@index([userId])
  // KPIs y listados de certificados por curso (panel del tutor y reportes).
  @@index([courseId])
  @@index([issuedAt])
}

// ------------------------------------------------------------------
// Configuración institucional, medios y auditoría
// ------------------------------------------------------------------

model InstitutionSettings {
  id              String  @id @default("singleton") // fila única
  institutionName String  @default("Red Salud Casanare E.S.E.")
  logoUrl         String?
  primaryColor    String  @default("#2BA6DE")
  navyColor       String  @default("#0F2438")
  contactEmail    String?
  contactPhone    String?
  certificateText String? // texto base del certificado
  signerName      String? // responsable certificador
  signerPosition  String? // cargo del responsable
  signatureUrl    String? // imagen de firma
  city            String  @default("Yopal, Casanare")
}

model Media {
  id         String   @id @default(cuid())
  fileName   String
  fileType   String // mime type
  fileUrl    String
  fileSize   Int // bytes
  folder     String? // organización simple por carpeta
  uploadedBy String
  uploader   User     @relation(fields: [uploadedBy], references: [id])
  createdAt  DateTime @default(now())

  // Documentos del plan de capacitaciones (Etapa 2): mismo modelo genérico
  // que ya usan lecciones y avatares, no un modelo de documento nuevo.
  trainingPlanId     String?
  trainingPlan       TrainingPlan?     @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  trainingActivityId String?
  trainingActivity   TrainingActivity? @relation(fields: [trainingActivityId], references: [id], onDelete: Cascade)

  @@index([folder])
  @@index([trainingPlanId])
  @@index([trainingActivityId])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String // CREATE, UPDATE, DELETE, LOGIN, ISSUE_CERT, REVOKE_CERT...
  entity      String // Course, User, Certificate...
  entityId    String?
  description String?
  createdAt   DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

// ------------------------------------------------------------------
// Centro de notificaciones
// ------------------------------------------------------------------

enum NotificationTargetType {
  ALL // todos los usuarios
  ROLE // todos los usuarios de un rol
  USER // un único usuario
}

enum NotificationSeverity {
  INFO
  SUCCESS
  WARNING
  DANGER
}

model Notification {
  id           String                  @id @default(cuid())
  title        String
  body         String
  severity     NotificationSeverity    @default(INFO)
  targetType   NotificationTargetType
  targetRole   Role?
  targetUserId String?
  targetUser   User?                   @relation("NotificationTargetUser", fields: [targetUserId], references: [id], onDelete: Cascade)
  createdById  String
  createdBy    User                    @relation("NotificationCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime                @default(now())

  reads NotificationRead[]

  @@index([targetType, targetRole])
  @@index([targetUserId])
  @@index([createdAt])
}

/** Estado de lectura por usuario; solo existe una fila una vez que el usuario la marca como leída. */
model NotificationRead {
  id             String       @id @default(cuid())
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("NotificationReadBy", fields: [userId], references: [id], onDelete: Cascade)
  readAt         DateTime     @default(now())

  @@unique([notificationId, userId])
}

// ------------------------------------------------------------------
// Plan de capacitaciones (Etapa 1: cronograma y plan)
// ------------------------------------------------------------------

enum TrainingPlanStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

/**
 * Gestionado por TUTOR (sus propios planes) y ADMIN (todos, sin límite,
 * incluyendo crear en nombre de un tutor). Una sola UI para ambos roles;
 * el alcance se filtra por rol en las queries, no se duplica la vista.
 */
model TrainingPlan {
  id               String             @id @default(cuid())
  title            String
  year             Int
  description      String?
  targetDepartment String? // mismo texto libre que User.department: sin modelo Department separado; null = todo el personal, cualquier área
  tutorId          String
  tutor            User               @relation("TrainingPlanTutor", fields: [tutorId], references: [id])
  status           TrainingPlanStatus @default(DRAFT)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  activities TrainingActivity[]
  documents  Media[]
  surveys    Survey[]

  @@index([tutorId])
  @@index([targetDepartment])
}

enum TrainingActivityType {
  COURSE // vinculada a un curso existente de la plataforma
  EXTERNAL_EVENT // evento externo presencial, sin curso asociado
}

/**
 * Ciclo de vida real de la jornada (Etapa 6): BORRADOR -> ABIERTA (visible
 * a estudiantes del área, admite respuestas) -> CERRADA (participación
 * congelada, indicadores consolidados). El campo se define ahora; el flujo
 * de habilitar/cerrar se construye en su propia etapa.
 */
enum TrainingActivityStatus {
  DRAFT
  OPEN
  CLOSED
}

model TrainingActivity {
  id             String                 @id @default(cuid())
  planId         String
  plan           TrainingPlan           @relation(fields: [planId], references: [id], onDelete: Cascade)
  title          String
  type           TrainingActivityType
  courseId       String? // opcional siempre: "No aplica" = gestión directa, sin curso vinculado
  course         Course?                @relation(fields: [courseId], references: [id])
  startDate      DateTime
  endDate        DateTime?
  targetAudience CourseAudience         @default(AMBOS) // reutiliza el enum de Course, misma semántica
  isRequired     Boolean                @default(true)
  status         TrainingActivityStatus @default(DRAFT)
  enabledAt      DateTime? // Etapa 6: cuándo pasó a ABIERTA
  closedAt       DateTime? // Etapa 6: cuándo se cerró (participación congelada desde ese momento)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  documents   Media[]
  attendances TrainingAttendance[]
  surveys     Survey[]

  @@index([planId])
  @@index([courseId])
}

/**
 * Etapa 3: solo existe cuando la actividad NO tiene curso vinculado (evento
 * externo, o "No aplica" con gestión directa) — sin curso no hay señal de
 * completitud automática, así que la asistencia se registra manualmente.
 * Las actividades con curso vinculado calculan adherencia en vivo desde
 * Enrollment, sin necesidad de esta tabla.
 */
model TrainingAttendance {
  id           String           @id @default(cuid())
  activityId   String
  activity     TrainingActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  userId       String
  user         User             @relation("TrainingAttendanceUser", fields: [userId], references: [id], onDelete: Cascade)
  attended     Boolean          @default(false)
  registeredAt DateTime         @default(now())
  registeredBy String
  registeredByUser User         @relation("TrainingAttendanceRegisteredBy", fields: [registeredBy], references: [id])

  @@unique([activityId, userId])
  @@index([activityId])
}

// ------------------------------------------------------------------
// Etapa 4: encuestas de opinión (detección de necesidades / evaluación
// post-capacitación). Distinto de Quiz: sin nota de aprobación, sin
// intentos, una sola respuesta por usuario. Solo responden usuarios de la
// plataforma con sesión iniciada (sin enlace público) — población fija y
// verificable.
// ------------------------------------------------------------------

enum SurveyQuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  SCALE // escala Likert 1..N (scaleMin/scaleMax en la pregunta)
  TEXT
}

model Survey {
  id   String  @id @default(cuid())
  title       String
  description String?

  trainingPlanId     String
  trainingPlan       TrainingPlan      @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  trainingActivityId String? // si se asigna: encuesta de esa jornada puntual ("participantes de la actividad"); si no, del plan en general
  trainingActivity   TrainingActivity? @relation(fields: [trainingActivityId], references: [id], onDelete: Cascade)

  // Audiencia objetivo (Etapa 3, mismo mecanismo): dependencia + tipo de personal.
  // targetDepartment null = todo el personal, cualquier área.
  targetDepartment String?
  targetAudience   CourseAudience @default(AMBOS)

  createdBy String
  creator   User     @relation("SurveyCreatedBy", fields: [createdBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions SurveyQuestion[]
  responses SurveyResponse[]

  @@index([trainingPlanId])
  @@index([trainingActivityId])
}

model SurveyQuestion {
  id         String             @id @default(cuid())
  surveyId   String
  survey     Survey             @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  type       SurveyQuestionType
  statement  String
  isRequired Boolean            @default(true)
  scaleMin   Int?               @default(1) // solo type = SCALE
  scaleMax   Int?               @default(5) // solo type = SCALE
  sortOrder  Int

  options SurveyQuestionOption[]
  answers SurveyAnswer[]

  @@unique([surveyId, sortOrder])
}

model SurveyQuestionOption {
  id         String         @id @default(cuid())
  questionId String
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  sortOrder  Int

  selectedIn SurveyAnswerOption[]

  @@unique([questionId, sortOrder])
}

/** Una fila por usuario por encuesta: garantiza una sola respuesta (no hay "intentos"). */
model SurveyResponse {
  id          String   @id @default(cuid())
  surveyId    String
  survey      Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation("SurveyRespondedBy", fields: [userId], references: [id], onDelete: Cascade)
  submittedAt DateTime @default(now())

  answers SurveyAnswer[]

  @@unique([surveyId, userId])
}

model SurveyAnswer {
  id         String         @id @default(cuid())
  responseId String
  response   SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId String
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  textValue  String? // type = TEXT
  scaleValue Int? // type = SCALE

  selectedOptions SurveyAnswerOption[] // type = SINGLE_CHOICE / MULTIPLE_CHOICE

  @@unique([responseId, questionId])
}

model SurveyAnswerOption {
  id       String               @id @default(cuid())
  answerId String
  answer   SurveyAnswer         @relation(fields: [answerId], references: [id], onDelete: Cascade)
  optionId String
  option   SurveyQuestionOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([answerId, optionId])
}

// ------------------------------------------------------------------
// Recuperación de contraseña por código enviado al correo
// ------------------------------------------------------------------

/**
 * Código de un solo uso para restablecer la contraseña.
 *
 * Se guarda el HASH del código, nunca el código en claro: quien tenga acceso
 * a la base no debe poder tomar cuentas ajenas. Lleva contador de intentos
 * para frenar la adivinación por fuerza bruta de un código de 6 dígitos.
 */
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}
