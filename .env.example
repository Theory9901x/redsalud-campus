# Copia este archivo como .env y completa los valores reales. .env nunca se sube a git.

# Conexión a PostgreSQL. En desarrollo local, apunta al túnel SSH (localhost:5433 -> VPS:5432).
# En producción (en el propio VPS), apunta directo a localhost:5432.
DATABASE_URL="postgresql://redsalud:TU_CONTRASEÑA@localhost:5433/redsalud_dev?schema=public"

# Clave secreta para firmar los JWT de sesión (Auth.js). Genera la tuya con:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="GENERA_LA_TUYA_NO_USES_ESTA"

# URL pública del sitio (sin barra final). Se usa para construir la URL que
# codifica el QR de los certificados. En producción, la URL real del dominio.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Requerido en producción (detrás de nginx como reverse proxy): sin esto,
# Auth.js rechaza las peticiones con "UntrustedHost" porque no reconoce el
# Host que le llega a través del proxy. No hace falta en desarrollo local.
AUTH_TRUST_HOST=true
